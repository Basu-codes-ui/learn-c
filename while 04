#include <stdio.h>

int main()
{
    int i = 1, j, space, n = 5;

    while (i <= n)
    {
        space = 1;
        
        // Print spaces
        while (space <= n - i)
        {
            printf(" ");
            space++;
        }

        j = 1;
        // Print stars
        while (j <= (2 * i - 1))
        {
            printf("*");
            j++;
        }

        printf("\n");
        i++;
    }

    return 0;
} 
