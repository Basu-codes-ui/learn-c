#include <stdio.h>

int main()
{
    int arr[10], i, n;

    printf("Enter how many values:\n");
    scanf("%d", &n);

    printf("Enter values one by one:\n");
    for(i = 0; i < n; i++)
    {
        scanf("%d", &arr[i]);
    }

    printf("Output of array elements:\n");
    for(i = 0; i < n; i++)
    {
        printf("%d\n", arr[i]);
    }

    return 0;
}
