#include <stdio.h>
#define PI 3.142

int main()
{
    float radius, area, perimeter;

    printf("Enter radius of the circle: ");
    scanf("%f", &radius);

    area = PI * radius * radius;
    perimeter = 2 * PI * radius;

    printf("Area = %f\n", area);
    printf("Perimeter = %f\n", perimeter);

    return 0;
}